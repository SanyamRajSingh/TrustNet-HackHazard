# TrustNet Environment Variables

# App
ENV=development
DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgresql://trustnet:password@localhost:5432/trustnet

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0

# Sarvam AI
SARVAM_API_KEY=your-sarvam-api-key

# External APIs
WHOIS_API_KEY=your-whoisxml-api-key
GOOGLE_SAFE_BROWSING_KEY=your-safe-browsing-key
PHISHTANK_API_KEY=your-phishtank-key
NUMVERIFY_API_KEY=your-numverify-key
CLOUDINARY_URL=

# Blockchain
BASE_SEPOLIA_RPC=https://sepolia.base.org
BACKEND_WALLET_PRIVATE_KEY=0x...
TRUSTNET_CONTRACT_ADDRESS=0x...
BLOCKCHAIN_ENABLED=false

# Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://trustnet.onrender.com